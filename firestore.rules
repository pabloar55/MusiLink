rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isActiveUser(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.username != 'deleted_user';
    }

    function hasBlocked(blockerId, blockedId) {
      return exists(/databases/$(database)/documents/user_private/$(blockerId))
        && get(/databases/$(database)/documents/user_private/$(blockerId))
          .data
          .get('blockedUsers', [])
          .hasAny([blockedId]);
    }

    function canUsersInteract(userA, userB) {
      return userA != userB
        && !hasBlocked(userA, userB)
        && !hasBlocked(userB, userA);
    }

    function areMutualFriends(userA, userB) {
      return exists(/databases/$(database)/documents/user_private/$(userA))
        && exists(/databases/$(database)/documents/user_private/$(userB))
        && get(/databases/$(database)/documents/user_private/$(userA))
          .data.get('friends', []).hasAny([userB])
        && get(/databases/$(database)/documents/user_private/$(userB))
          .data.get('friends', []).hasAny([userA]);
    }

    function validHttpsUrl(value, allowEmpty) {
      return value is string
        && value.toUtf8().size() <= 2048
        && (allowEmpty && value == '' || value.matches('^https://.*$'));
    }

    function validTrackData(track) {
      return track is map
        && track.keys().hasOnly(['title', 'artist', 'imageUrl', 'spotifyUrl'])
        && track.keys().hasAll(['title', 'artist', 'imageUrl', 'spotifyUrl'])
        && track.title is string
        && track.title.toUtf8().size() > 0
        && track.title.toUtf8().size() <= 300
        && track.artist is string
        && track.artist.toUtf8().size() > 0
        && track.artist.toUtf8().size() <= 300
        && validHttpsUrl(track.imageUrl, true)
        && validHttpsUrl(track.spotifyUrl, true);
    }

    function validPublicProfile(data) {
      return data.displayName is string
        && data.displayName.toUtf8().size() > 0
        && data.displayName.toUtf8().size() <= 100
        && data.username is string
        && data.username.matches('^[a-z0-9_]{3,20}$')
        && validHttpsUrl(data.get('photoUrl', ''), true)
        && (!('spotifyId' in data)
          || data.spotifyId is string && data.spotifyId.toUtf8().size() <= 128)
        && (!('topArtists' in data)
          || data.topArtists is list && data.topArtists.size() <= 50)
        && (!('topGenres' in data)
          || data.topGenres is list && data.topGenres.size() <= 10)
        && (!('topArtistNames' in data)
          || data.topArtistNames is list && data.topArtistNames.size() <= 50)
        && (!('topGenreNames' in data)
          || data.topGenreNames is list && data.topGenreNames.size() <= 10)
        && (!('musicDataUpdatedAt' in data) || data.musicDataUpdatedAt is timestamp)
        && (!('dailySong' in data) || validTrackData(data.dailySong))
        && (!('dailySongUpdatedAt' in data) || data.dailySongUpdatedAt is timestamp)
        && (!('recommendationsRefreshRequestedAt' in data)
          || data.recommendationsRefreshRequestedAt is timestamp);
    }

    function validBlockedUsers(userId, data) {
      return !('blockedUsers' in data)
        || (
          data.blockedUsers is list
          && data.blockedUsers.size() <= 1000
          && data.blockedUsers.toSet().size() == data.blockedUsers.size()
          && !data.blockedUsers.hasAny([userId])
        );
    }

    function validPrivateProfile(userId, data) {
      return validBlockedUsers(userId, data)
        && validFriends(userId, data)
        && (!('email' in data)
          || data.email is string && data.email.toUtf8().size() <= 320)
        && (!('createdAt' in data) || data.createdAt is timestamp)
        && (!('lastLogin' in data) || data.lastLogin is timestamp)
        && (!('deletedAt' in data) || data.deletedAt is timestamp)
        && (!('fcmToken' in data)
          || data.fcmToken is string && data.fcmToken.toUtf8().size() <= 4096)
        && (!('preferredLocale' in data)
          || data.preferredLocale in ['en', 'es', 'fr'])
        && (!('notifSound' in data) || data.notifSound is bool)
        && (!('notifVibration' in data) || data.notifVibration is bool);
    }

    function validPushToken(data) {
      return data.keys().hasOnly([
          'token',
          'platform',
          'preferredLocale',
          'updatedAt',
        ])
        && data.keys().hasAll([
          'token',
          'platform',
          'preferredLocale',
          'updatedAt',
        ])
        && data.token is string
        && data.token.toUtf8().size() > 0
        && data.token.toUtf8().size() <= 4096
        && data.platform in ['android', 'ios', 'web']
        && data.preferredLocale in ['en', 'es', 'fr']
        && data.updatedAt == request.time;
    }

    function validFriends(userId, data) {
      return !('friends' in data)
        || (
          data.friends is list
          && data.friends.size() <= 1000
          && data.friends.toSet().size() == data.friends.size()
          && !data.friends.hasAny([userId])
        );
    }

    function ownerOnlyRemovesAtMostOneFriend(userId) {
      let before = resource.data.get('friends', []);
      let after = request.resource.data.get('friends', []);
      return request.auth.uid == userId
        && before is list
        && after is list
        && before.hasAll(after)
        && before.size() >= after.size()
        && before.size() <= after.size() + 1;
    }

    // ─── Usuarios ───────────────────────────────────────
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer perfiles (necesario para búsqueda y avatares)
      allow read: if request.auth != null;
      // El propio usuario puede crear su perfil
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'displayName',
          'username',
          'photoUrl',
        ])
        && request.resource.data.keys().hasAll(['displayName', 'username', 'photoUrl'])
        && validPublicProfile(request.resource.data);
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'username',
          'photoUrl',
          'spotifyId',
          'topArtists',
          'topGenres',
          'topArtistNames',
          'topGenreNames',
          'musicDataUpdatedAt',
          'dailySong',
          'dailySongUpdatedAt',
          'recommendationsRefreshRequestedAt',
        ])
        && validPublicProfile(request.resource.data);
      allow delete: if false;

      match /recommendations/{recommendationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    match /user_private/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'email',
          'createdAt',
          'lastLogin',
          'friends',
          'blockedUsers',
          'fcmToken',
          'preferredLocale',
          'notifSound',
          'notifVibration',
        ])
        && validPrivateProfile(userId, request.resource.data)
        && request.resource.data.get('friends', []).size() == 0;
      allow update: if request.auth != null && (
        (
          request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'email',
            'lastLogin',
            'friends',
            'blockedUsers',
            'fcmToken',
            'preferredLocale',
            'deletedAt',
            'notifSound',
            'notifVibration',
          ])
          && validPrivateProfile(userId, request.resource.data)
          && ownerOnlyRemovesAtMostOneFriend(userId)
        )
        ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends'])
          && validFriends(userId, request.resource.data)
          && resource.data.get('friends', []).hasAll(request.resource.data.friends)
          && request.resource.data.friends.size() == resource.data.get('friends', []).size() - 1
          && !request.resource.data.friends.hasAny([request.auth.uid])
          && resource.data.get('friends', []).hasAny([request.auth.uid])
        )
      );
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /push_tokens/{installationId} {
        allow read, delete: if request.auth != null
          && request.auth.uid == userId;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && installationId.matches('^[A-Za-z0-9_-]{20,64}$')
          && validPushToken(request.resource.data);
      }
    }

    // ─── Solicitudes de amistad ───────────────────────────
    match /friend_requests/{requestId} {
      // Solo el remitente o destinatario puede leer.
      // resource == null cubre el caso en que el doc aún no existe (p.ej. tx.get
      // dentro de sendRequest para comprobar duplicados antes de crear).
      allow read: if request.auth != null
        && (resource == null
            || request.auth.uid == resource.data.senderId
            || request.auth.uid == resource.data.receiverId);
      // Solo el remitente puede crear, con ID determinista senderId_receiverId.
      // El ID determinista hace que un segundo intento sea tratado como update
      // (rechazado por la regla de update), previniendo solicitudes duplicadas.
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'senderId',
          'receiverId',
          'status',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && friendRequestRateLimitAllows(request.auth.uid)
        && isActiveUser(request.resource.data.receiverId)
        && canUsersInteract(request.resource.data.senderId, request.resource.data.receiverId)
        && requestId == request.resource.data.senderId + '_' + request.resource.data.receiverId
        && !exists(/databases/$(database)/documents/friend_requests/$(request.resource.data.receiverId + '_' + request.resource.data.senderId));
      // Solo el destinatario puede aceptar una solicitud pendiente. Rechazar y
      // cancelar se implementan borrando el documento.
      allow update: if request.auth != null
        && request.auth.uid == resource.data.receiverId
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && canUsersInteract(resource.data.senderId, resource.data.receiverId);
      // Ambos pueden eliminar
      allow delete: if request.auth != null
        && (resource == null
            || request.auth.uid == resource.data.senderId
            || request.auth.uid == resource.data.receiverId);
    }

    // ─── Chats ──────────────────────────────────────────
    function validReactionUsers(reactions, participants, emoji) {
      let users = reactions.get(emoji, []);
      return users is list
        && users.size() <= participants.size()
        && users.hasOnly(participants)
        && users.toSet().size() == users.size()
        && (!(emoji in reactions) || users.size() > 0);
    }

    function validReactions(reactions, participants) {
      return reactions is map
        && reactions.keys().hasOnly(['❤️', '🔥', '👏', '😍', '💀'])
        && reactions.size() <= 2
        && validReactionUsers(reactions, participants, '❤️')
        && validReactionUsers(reactions, participants, '🔥')
        && validReactionUsers(reactions, participants, '👏')
        && validReactionUsers(reactions, participants, '😍')
        && validReactionUsers(reactions, participants, '💀')
        && (
          reactions.size() < 2
          || !reactions[reactions.keys()[0]].hasAny(reactions[reactions.keys()[1]])
        );
    }

    function otherParticipant(participants, userId) {
      return participants[0] == userId ? participants[1] : participants[0];
    }

    function otherReactionUnchanged(before, after, otherId, emoji) {
      return before.get(emoji, []).hasAny([otherId])
        == after.get(emoji, []).hasAny([otherId]);
    }

    function validReactionMutation(participants) {
      let before = resource.data.get('reactions', {});
      let after = request.resource.data.get('reactions', {});
      let otherId = otherParticipant(participants, request.auth.uid);
      return validReactions(after, participants)
        && otherReactionUnchanged(before, after, otherId, '❤️')
        && otherReactionUnchanged(before, after, otherId, '🔥')
        && otherReactionUnchanged(before, after, otherId, '👏')
        && otherReactionUnchanged(before, after, otherId, '😍')
        && otherReactionUnchanged(before, after, otherId, '💀');
    }

    function validUnreadCounts(counts, participants) {
      return counts is map
        && counts.keys().hasOnly(participants)
        && counts.keys().hasAll(participants)
        && counts[participants[0]] is int
        && counts[participants[0]] >= 0
        && counts[participants[1]] is int
        && counts[participants[1]] >= 0;
    }

    function validReadCounterReset(before, after, participants) {
      let readerId = request.auth.uid;
      let otherId = otherParticipant(participants, readerId);
      return after.diff(before).affectedKeys().hasOnly(['unreadCounts'])
        && validUnreadCounts(after.unreadCounts, participants)
        && after.unreadCounts.diff(before.unreadCounts).affectedKeys().hasOnly([readerId])
        && after.unreadCounts[readerId] == 0
        && after.unreadCounts[otherId] == before.unreadCounts[otherId];
    }

    function chatDeletedFor(chat, userId) {
      return chat.get('deletedAt', {}).get(userId, null) is timestamp
        && chat.lastMessageTime <= chat.get('deletedAt', {}).get(userId, request.time);
    }

    function fullySoftDeletedChat(chat) {
      return chat.participants is list
        && chat.participants.size() == 2
        && chatDeletedFor(chat, chat.participants[0])
        && chatDeletedFor(chat, chat.participants[1]);
    }

    function messageRateLimitAllows(userId) {
      let after = getAfter(/databases/$(database)/documents/rate_limits/$(userId)).data;
      let before = get(/databases/$(database)/documents/rate_limits/$(userId)).data;
      return after.lastMessageAt == request.time
        && (
          !exists(/databases/$(database)/documents/rate_limits/$(userId))
          || !('messageWindowStart' in before)
          || request.time > before.messageWindowStart + duration.value(10, 's')
          || (
            after.messageWindowStart == before.messageWindowStart
            && after.messageCount == before.messageCount + 1
            && after.messageCount <= 20
          )
        )
        && (
          exists(/databases/$(database)/documents/rate_limits/$(userId))
          && ('messageWindowStart' in before)
          && request.time <= before.messageWindowStart + duration.value(10, 's')
          || (
            after.messageWindowStart == request.time
            && after.messageCount == 1
          )
        );
    }

    function friendRequestRateLimitAllows(userId) {
      let after = getAfter(/databases/$(database)/documents/rate_limits/$(userId)).data;
      let before = get(/databases/$(database)/documents/rate_limits/$(userId)).data;
      return after.lastFriendRequestAt == request.time
        && (
          !exists(/databases/$(database)/documents/rate_limits/$(userId))
          || !('friendRequestWindowStart' in before)
          || request.time > before.friendRequestWindowStart + duration.value(10, 'm')
          || (
            after.friendRequestWindowStart == before.friendRequestWindowStart
            && after.friendRequestCount == before.friendRequestCount + 1
            && after.friendRequestCount <= 20
          )
        )
        && (
          exists(/databases/$(database)/documents/rate_limits/$(userId))
          && ('friendRequestWindowStart' in before)
          && request.time <= before.friendRequestWindowStart + duration.value(10, 'm')
          || (
            after.friendRequestWindowStart == request.time
            && after.friendRequestCount == 1
          )
        );
    }

    function validRateLimitCreate() {
      return request.resource.data.keys().hasOnly([
          'lastMessageAt',
          'messageWindowStart',
          'messageCount',
          'lastFriendRequestAt',
          'friendRequestWindowStart',
          'friendRequestCount',
        ])
        && (!('lastMessageAt' in request.resource.data)
            || (
              request.resource.data.lastMessageAt == request.time
              && request.resource.data.messageWindowStart == request.time
              && request.resource.data.messageCount == 1
            ))
        && (!('lastFriendRequestAt' in request.resource.data)
            || (
              request.resource.data.lastFriendRequestAt == request.time
              && request.resource.data.friendRequestWindowStart == request.time
              && request.resource.data.friendRequestCount == 1
            ));
    }

    function validMessageRateLimitUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['lastMessageAt', 'messageWindowStart', 'messageCount'])
        && request.resource.data.lastMessageAt == request.time
        && (
          !('messageWindowStart' in resource.data)
          || request.time > resource.data.messageWindowStart + duration.value(10, 's')
          || (
            request.resource.data.messageWindowStart == resource.data.messageWindowStart
            && request.resource.data.messageCount == resource.data.messageCount + 1
            && request.resource.data.messageCount <= 20
          )
        )
        && (
          ('messageWindowStart' in resource.data)
          && request.time <= resource.data.messageWindowStart + duration.value(10, 's')
          || (
            request.resource.data.messageWindowStart == request.time
            && request.resource.data.messageCount == 1
          )
        );
    }

    function validFriendRequestRateLimitUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['lastFriendRequestAt', 'friendRequestWindowStart', 'friendRequestCount'])
        && request.resource.data.lastFriendRequestAt == request.time
        && (
          !('friendRequestWindowStart' in resource.data)
          || request.time > resource.data.friendRequestWindowStart + duration.value(10, 'm')
          || (
            request.resource.data.friendRequestWindowStart == resource.data.friendRequestWindowStart
            && request.resource.data.friendRequestCount == resource.data.friendRequestCount + 1
            && request.resource.data.friendRequestCount <= 20
          )
        )
        && (
          ('friendRequestWindowStart' in resource.data)
          && request.time <= resource.data.friendRequestWindowStart + duration.value(10, 'm')
          || (
            request.resource.data.friendRequestWindowStart == request.time
            && request.resource.data.friendRequestCount == 1
          )
        );
    }

    match /rate_limits/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && validRateLimitCreate();
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (
          validMessageRateLimitUpdate()
          || validFriendRequestRateLimitUpdate()
        );
      allow delete: if false;
    }

    match /chats/{chatId} {
      // Solo los participantes pueden leer el chat.
      // resource == null cubre el caso en que el doc aún no existe (p.ej. tx.get
      // dentro de getOrCreateChat para comprobar si el chat existe antes de crearlo).
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.participants);

      // Solo se puede crear un chat con un ID determinista: los dos UIDs de los
      // participantes ordenados lexicográficamente y unidos por "_".
      // Esto evita que dos clientes concurrentes creen documentos duplicados
      // para el mismo par de usuarios, ya que cualquier ID aleatorio será
      // rechazado por esta regla.
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'participants',
          'lastMessage',
          'lastMessageTime',
          'createdAt',
          'unreadCounts',
        ])
        && request.resource.data.keys().hasAll([
          'participants',
          'lastMessage',
          'lastMessageTime',
          'createdAt',
          'unreadCounts',
        ])
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants[0] < request.resource.data.participants[1]
        && request.resource.data.lastMessage == ''
        && request.resource.data.lastMessageTime == request.time
        && request.resource.data.createdAt == request.time
        && validUnreadCounts(
          request.resource.data.unreadCounts,
          request.resource.data.participants
        )
        && request.resource.data.unreadCounts[request.resource.data.participants[0]] == 0
        && request.resource.data.unreadCounts[request.resource.data.participants[1]] == 0
        && isActiveUser(request.resource.data.participants[0])
        && isActiveUser(request.resource.data.participants[1])
        && canUsersInteract(
          request.resource.data.participants[0],
          request.resource.data.participants[1]
        )
        && areMutualFriends(
          request.resource.data.participants[0],
          request.resource.data.participants[1]
        )
        && chatId == request.resource.data.participants[0] + '_' + request.resource.data.participants[1];

      // Los resúmenes y los incrementos de contadores los actualiza únicamente
      // onNewMessage con Admin SDK. El cliente solo puede limpiar su contador o
      // escribir su propia marca de borrado suave.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && (
          // Caso 1: el usuario solo puede poner a cero su propio contador.
          (
            canUsersInteract(resource.data.participants[0], resource.data.participants[1])
            && areMutualFriends(resource.data.participants[0], resource.data.participants[1])
            && validReadCounterReset(
              resource.data,
              request.resource.data,
              resource.data.participants
            )
          )
          ||
          // Caso 2: borrado suave — solo cambia deletedAt[request.auth.uid].
          (
            request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(['deletedAt'])
            && request.resource.data.deletedAt is map
            && request.resource.data.deletedAt.keys().hasOnly(resource.data.participants)
            && request.resource.data.deletedAt
                 .diff(resource.data.get('deletedAt', {}))
                 .affectedKeys()
                 .hasOnly([request.auth.uid])
            && request.resource.data.deletedAt[request.auth.uid] == request.time
          )
        );

      // Compatibilidad: clientes antiguos pueden intentar borrar el doc del chat
      // durante limpieza de cuenta o despues de un borrado suave doble. Cloud
      // Functions restaura chats no vacios que no estaban borrados por ambos.
      allow delete: if false;

      // ─── Mensajes (subcolección) ────────────────────
      match /messages/{messageId} {
        // Solo los participantes del chat padre pueden leer mensajes
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Solo un participante puede crear un mensaje, y debe ser el remitente
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.keys().hasOnly([
            'senderId',
            'text',
            'timestamp',
            'read',
            'type',
            'trackData',
          ])
          && request.resource.data.keys().hasAll([
            'senderId',
            'text',
            'timestamp',
            'read',
            'type',
          ])
          && canUsersInteract(
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants[0],
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants[1]
          )
          && areMutualFriends(
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants[0],
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants[1]
          )
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.timestamp == request.time
          && request.resource.data.read == false
          && request.resource.data.type in ['text', 'track']
          && (
            (
              request.resource.data.type == 'text'
              && !('trackData' in request.resource.data)
            )
            ||
            (
              request.resource.data.type == 'track'
              && 'trackData' in request.resource.data
              && validTrackData(request.resource.data.trackData)
            )
          )
          && messageRateLimitAllows(request.auth.uid)
          && request.resource.data.text is string
          && request.resource.data.text.toUtf8().size() > 0
          && request.resource.data.text.toUtf8().size() <= 2000;

        // La lectura solo puede hacerla el receptor (false -> true). En una
        // reacción, cada participante solo puede cambiar su propia pertenencia.
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && canUsersInteract(
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants[0],
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants[1]
          )
          && areMutualFriends(
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants[0],
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants[1]
          )
          && (
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
              && request.auth.uid != resource.data.senderId
              && resource.data.read == false
              && request.resource.data.read == true
            )
            ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
              && request.resource.data.diff(resource.data).affectedKeys().hasAll(['reactions'])
              && areMutualFriends(
                get(/databases/$(database)/documents/chats/$(chatId)).data.participants[0],
                get(/databases/$(database)/documents/chats/$(chatId)).data.participants[1]
              )
              && (
                canUsersInteract(
                  get(/databases/$(database)/documents/chats/$(chatId)).data.participants[0],
                  get(/databases/$(database)/documents/chats/$(chatId)).data.participants[1]
                )
                && validReactionMutation(
                  get(/databases/$(database)/documents/chats/$(chatId)).data.participants
                )
              )
            )
          );

        // El remitente puede eliminar sus propios mensajes. Si ambos usuarios
        // borraron el chat, un cliente antiguo tambien puede completar la
        // limpieza fisica; Cloud Functions hace el mismo trabajo para clientes nuevos.
        allow delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && (
            resource.data.senderId == request.auth.uid
            || fullySoftDeletedChat(get(/databases/$(database)/documents/chats/$(chatId)).data)
          );
      }
    }
  }
}
